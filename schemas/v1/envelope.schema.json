{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/dreamabout/kaikei-envelope/schemas/v1/envelope.schema.json",
    "title": "Kaikei v1 envelope",
    "description": "Faithful mirror of Kaikei's current wire contract (PayloadValidator on dreamabout/kaikei:main). This is the byte-shape both systems exchange today; the package's v2 contract is the cleaner forward redesign.",
    "type": "object",
    "additionalProperties": false,
    "required": ["event_id", "event_type", "schema_version", "occurred_at", "data"],
    "properties": {
        "event_id": {
            "type": "string",
            "description": "ULID (Crockford Base32, 26 chars) OR UUID. Kaikei dedups on this.",
            "pattern": "^([0-9A-HJKMNP-TV-Z]{26}|[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12})$"
        },
        "event_type": {
            "type": "string",
            "enum": ["order.shipped", "order.captured", "order.refunded", "payout.paid", "payment.prepaid"]
        },
        "schema_version": {
            "type": "integer",
            "description": "v1 contract.",
            "const": 1
        },
        "occurred_at": {
            "type": "string",
            "description": "RFC 3339 timestamp, UTC.",
            "format": "date-time"
        },
        "data": {
            "type": "object",
            "description": "Per-event-type payload. Validated against the matching v1 payload schema selected by event_type."
        }
    }
}
