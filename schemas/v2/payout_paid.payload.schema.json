{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/dreamabout/kaikei-envelope/schemas/v2/payout_paid.payload.schema.json",
    "title": "payout.paid payload",
    "type": "object",
    "additionalProperties": false,
    "required": ["payout_id", "gateway", "transaction_ids", "gross_amount", "fee_amount", "net_amount", "paid_at"],
    "properties": {
        "payout_id": { "type": "string", "minLength": 1 },
        "gateway": { "type": "string", "minLength": 1 },
        "transaction_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
        },
        "gross_amount": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" },
        "fee_amount": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" },
        "net_amount": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" },
        "paid_at": { "type": "string", "format": "date-time" },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "fx_rate": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" }
    }
}
