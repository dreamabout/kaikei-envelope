{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/dreamabout/kaikei-envelope/schemas/v2/account_fee.payload.schema.json",
    "title": "account.fee payload",
    "description": "A standing shop-level provider account fee (e.g. Rapyd's daily account fee), not tied to any order. The receiver books it debit gateway_fee(gateway, 'account') / credit gateway_clearing(gateway). amount > 0 is enforced as a cross-field invariant in PayloadValidator.",
    "type": "object",
    "additionalProperties": false,
    "required": ["fee_id", "gateway", "amount", "incurred_at"],
    "properties": {
        "fee_id": { "type": "string", "minLength": 1 },
        "gateway": { "type": "string", "minLength": 1 },
        "amount": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "fx_rate": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" },
        "incurred_at": { "type": "string", "format": "date-time" }
    }
}
