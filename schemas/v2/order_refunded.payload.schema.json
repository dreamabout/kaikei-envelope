{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/dreamabout/kaikei-envelope/schemas/v2/order_refunded.payload.schema.json",
    "title": "order.refunded payload",
    "type": "object",
    "additionalProperties": false,
    "required": ["order_id", "reason", "items", "refund_payments"],
    "properties": {
        "order_id": { "type": "string", "minLength": 1 },
        "reason": {
            "type": "string",
            "enum": ["customer_request", "chargeback", "merchant_initiated", "other"]
        },
        "items": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/item" }
        },
        "refund_payments": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/refund_payment" }
        },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "fx_rate": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" },
        "prepayment_event_id": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
        "credit_note_number": { "type": "string", "minLength": 1 }
    },
    "$defs": {
        "item": {
            "type": "object",
            "required": ["type", "gross_amount", "vat_amount", "vat_rate"],
            "properties": {
                "type": { "type": "string", "enum": ["physical", "gift_card", "digital", "shipping", "fee", "giftwrapping"] },
                "gross_amount": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" },
                "vat_amount": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" },
                "vat_rate": { "type": "string", "pattern": "^-?\\d+\\.\\d{2,4}$" },
                "unit_cost": { "type": "string", "pattern": "^\\d+\\.\\d{2}$" }
            }
        },
        "refund_payment": {
            "type": "object",
            "required": ["gateway", "original_transaction_id", "refund_transaction_id", "amount"],
            "properties": {
                "gateway": { "type": "string", "minLength": 1 },
                "original_transaction_id": { "type": "string", "minLength": 1 },
                "refund_transaction_id": { "type": "string", "minLength": 1 },
                "amount": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" }
            }
        }
    }
}
