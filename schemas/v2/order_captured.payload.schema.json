{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/dreamabout/kaikei-envelope/schemas/v2/order_captured.payload.schema.json",
    "title": "order.captured payload",
    "type": "object",
    "additionalProperties": false,
    "required": ["order_id", "gateway", "transaction_id", "amount", "captured_at"],
    "properties": {
        "order_id": { "type": "string", "minLength": 1 },
        "gateway": { "type": "string", "minLength": 1 },
        "transaction_id": { "type": "string", "minLength": 1 },
        "amount": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" },
        "captured_at": { "type": "string", "format": "date-time" },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "fx_rate": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" }
    }
}
