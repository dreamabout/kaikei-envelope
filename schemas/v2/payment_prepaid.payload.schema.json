{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/dreamabout/kaikei-envelope/schemas/v2/payment_prepaid.payload.schema.json",
    "title": "payment.prepaid payload",
    "type": "object",
    "additionalProperties": false,
    "required": ["order_id", "customer", "gateway", "transaction_id", "prepaid_at", "items"],
    "properties": {
        "order_id": { "type": "string", "minLength": 1 },
        "customer": { "$ref": "#/$defs/customer" },
        "gateway": { "type": "string", "minLength": 1 },
        "transaction_id": { "type": "string", "minLength": 1 },
        "prepaid_at": { "type": "string", "format": "date-time" },
        "items": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/item" }
        },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "fx_rate": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" },
        "invoice_number": { "type": "string", "minLength": 1 }
    },
    "$defs": {
        "customer": {
            "type": "object",
            "required": ["country_code", "is_b2b"],
            "properties": {
                "country_code": { "type": "string", "pattern": "^[A-Z]{2}$" },
                "is_b2b": { "type": "boolean" },
                "customer_id": { "type": "string", "minLength": 1 },
                "name": { "type": "string" },
                "email": { "type": "string" },
                "vat_number": { "type": "string" },
                "ean_number": { "type": "string", "pattern": "^[0-9]{13}$" },
                "address": {
                    "type": "object",
                    "properties": {
                        "street": { "type": "string" },
                        "city": { "type": "string" },
                        "postal_code": { "type": "string" },
                        "country": { "type": "string", "pattern": "^[A-Z]{2}$" }
                    }
                }
            }
        },
        "item": {
            "type": "object",
            "required": ["type", "gross_amount", "vat_amount", "vat_rate"],
            "properties": {
                "type": { "type": "string", "enum": ["physical", "gift_card", "digital"] },
                "gross_amount": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" },
                "vat_amount": { "type": "string", "pattern": "^-?\\d+\\.\\d{2}$" },
                "vat_rate": { "type": "string", "pattern": "^-?\\d+\\.\\d{2,4}$" }
            }
        }
    }
}
